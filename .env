PORT=3000
NODE_ENV=development

# MariaDB Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trash_clean
DB_USER=root
DB_PASSWORD=root

# JWT Secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_123456789

# File Upload Settings
MAX_FILE_SIZE=5242880

# Google Maps API Key (get from Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Redis (optional for production)
REDIS_URL=redis://localhost:6379

# Pickup Verification Settings
MAX_PICKUP_DISTANCE_METERS=50
POINTS_PER_PICKUP=10
MAX_PICKUPS_PER_HOUR=10

# AI/ML Service Keys (add your keys here)
# OPENAI_API_KEY=your_openai_key_here
# AWS_S3_BUCKET=trash-verification-images
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# OAuth2 Configuration
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Refresh Token Secret (separate from main JWT_SECRET for security)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_make_it_different_from_jwt_secret